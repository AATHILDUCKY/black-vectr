# ───────────────────────────────────────────────────────────────
# Shared / Backend environment
# Copy this file to `backend/.env` (and the FRONTEND block to `frontend/.env.local`)
# or keep a single root `.env` if you prefer — values below are read by the backend.
# ───────────────────────────────────────────────────────────────

# Backend
NODE_ENV=development
BACKEND_PORT=4000
# Origin allowed by CORS (the Next.js dev server)
FRONTEND_ORIGIN=http://localhost:3000

# Database (SQLite via Prisma). Path is relative to backend/prisma.
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Cookie name + lifetime (days)
AUTH_COOKIE_NAME=agency_token
COOKIE_SECURE=false

# Admin user created by the seed script (printed to console on seed)
ADMIN_EMAIL=admin@blackvectr.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Site Admin

# Email (Nodemailer). Leave SMTP_HOST empty to use a console/dev transport
# that just logs emails instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="BlackVectr <no-reply@blackvectr.com>"
# Where contact-form notifications are delivered
CONTACT_NOTIFY_TO=hello@blackvectr.com

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# ───────────────────────────────────────────────────────────────
# FRONTEND environment  → put these in frontend/.env.local
# ───────────────────────────────────────────────────────────────
# Base URL the browser/SSR uses to reach the API. In dev, Next rewrites
# `/api/*` to the backend, so the public base can stay relative.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-side calls (SSR) talk directly to the backend:
BACKEND_INTERNAL_URL=http://localhost:4000
